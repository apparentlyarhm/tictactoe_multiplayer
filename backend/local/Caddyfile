:8080 {
	@console host localhost
	handle @console {
		reverse_proxy nakama:7351 {
			lb_try_duration 5s
			lb_try_interval 500ms
		}
	}

	handle {
		reverse_proxy nakama:7350 {
			lb_try_duration 5s
			lb_try_interval 500ms
		}
	}

	handle_errors {
		@5xx `{err.status_code} >= 500 && {err.status_code} < 600`
		handle @5xx {
			respond "Server maybe starting up, refresh after a few seconds."
		}

		handle {
			respond ":< It's another error. Head over to https://arhm.dev to find a way to contact me. ^^"
		}
	}
}
